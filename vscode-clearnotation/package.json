{
  "name": "clearnotation",
  "displayName": "ClearNotation",
  "description": "Syntax highlighting for ClearNotation (.cln) technical documentation files",
  "version": "1.0.0",
  "publisher": "clearnotation",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rjmitchell/clear-notation"
  },
  "homepage": "https://github.com/rjmitchell/clear-notation",
  "keywords": [
    "clearnotation",
    "cln",
    "documentation",
    "markup",
    "technical writing"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:clearnotation"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "clearnotation",
        "aliases": [
          "ClearNotation",
          "cln"
        ],
        "extensions": [
          ".cln"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "clearnotation",
        "scopeName": "source.clearnotation",
        "path": "./syntaxes/clearnotation.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
