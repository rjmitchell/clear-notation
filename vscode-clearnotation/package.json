{
  "name": "clearnotation",
  "displayName": "ClearNotation",
  "description": "Language support for ClearNotation (.cln) files",
  "version": "0.9.0",
  "publisher": "clearnotation",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:clearnotation"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "clearnotation",
        "aliases": [
          "ClearNotation",
          "cln"
        ],
        "extensions": [
          ".cln"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "clearnotation",
        "scopeName": "source.clearnotation",
        "path": "./syntaxes/clearnotation.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
